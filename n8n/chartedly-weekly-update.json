{
  "name": "Chartedly Weekly Product Update",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtDay": 1,
              "triggerAtHour": 3
            }
          ]
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Every Monday 3AM JST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && git pull origin master 2>&1"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000002",
      "name": "1. Git Pull Latest",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [460, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && source .env && node scripts/fetch-rakuten.mjs --all 2>&1 | tail -30"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "2. Fetch Rakuten Rankings",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [680, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && source .env && node scripts/ai-enrich.mjs 2>&1 | tail -30"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000004",
      "name": "3. AI Enrich New Products",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [900, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && source .env && node scripts/sync-products.mjs 2>&1 | tail -15"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "4. Sync Products",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && PYTHONIOENCODING=utf-8 python3 scripts/remove-backgrounds.py 2>&1 | tail -15 && PYTHONIOENCODING=utf-8 python3 scripts/center-products.py 2>&1 | tail -15"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000006",
      "name": "5. Process Images",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [1340, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && npm run build 2>&1 | tail -5"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000007",
      "name": "6. Build Site",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [1560, 400]
    },
    {
      "parameters": {
        "command": "cd /opt/chartedly && git add -A && git diff --staged --quiet && echo 'No changes to commit' || (git commit -m \"Weekly product update $(date +%Y-%m-%d)\" && git push origin master && echo 'Changes committed and pushed!')"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000008",
      "name": "7. Commit & Push",
      "type": "n8n-nodes-base.exec",
      "typeVersion": 1,
      "position": [1780, 400]
    }
  ],
  "connections": {
    "Every Monday 3AM JST": {
      "main": [[{"node": "1. Git Pull Latest", "type": "main", "index": 0}]]
    },
    "1. Git Pull Latest": {
      "main": [[{"node": "2. Fetch Rakuten Rankings", "type": "main", "index": 0}]]
    },
    "2. Fetch Rakuten Rankings": {
      "main": [[{"node": "3. AI Enrich New Products", "type": "main", "index": 0}]]
    },
    "3. AI Enrich New Products": {
      "main": [[{"node": "4. Sync Products", "type": "main", "index": 0}]]
    },
    "4. Sync Products": {
      "main": [[{"node": "5. Process Images", "type": "main", "index": 0}]]
    },
    "5. Process Images": {
      "main": [[{"node": "6. Build Site", "type": "main", "index": 0}]]
    },
    "6. Build Site": {
      "main": [[{"node": "7. Commit & Push", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "Asia/Tokyo"
  }
}
