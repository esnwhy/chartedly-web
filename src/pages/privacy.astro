---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy — Chartedly" isArticle={true}>
  <div class="max-w-[768px] mx-auto px-4 sm:px-8 py-8">

    <h1 class="text-3xl font-extrabold mb-2" style="color: var(--color-text-primary);">Privacy Policy</h1>
    <p class="text-lg mb-8" style="color: var(--color-text-tertiary);">プライバシーポリシー</p>

    <p class="text-sm mb-8" style="color: var(--color-text-tertiary);">Last updated: March 2026</p>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Overview</h2>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        Chartedly is operated by LAIRIA. We respect your privacy and are committed to protecting any information collected through this website. This policy explains what data we collect, why, and how we use it.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Information We Collect</h2>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        Chartedly does not require user accounts, logins, or any personal information to use the site. We do not collect names, email addresses, or payment information through normal site usage.
      </p>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        We use <strong style="color: var(--color-text-primary);">Google Analytics (GA4)</strong> to collect anonymized usage data, including:
      </p>
      <ul class="list-disc pl-6 space-y-2 mb-4" style="color: var(--color-text-secondary);">
        <li>Pages visited and time spent on each page</li>
        <li>Referring websites and search terms</li>
        <li>Device type, browser, and operating system</li>
        <li>Approximate geographic location (country/city level)</li>
      </ul>
      <p class="leading-relaxed" style="color: var(--color-text-secondary);">
        This data is used solely to improve the site and understand which content is most useful to our readers.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Cookies</h2>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        We use cookies only for analytics purposes through Google Analytics. These cookies help us understand site traffic patterns. No advertising or tracking cookies are used. See our <a href="/cookies" style="color: var(--color-text-primary); text-decoration: underline;">Cookie Policy</a> for details.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Affiliate Links</h2>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        Chartedly contains affiliate links to Amazon JP and other retailers. When you click these links, the retailer may set their own cookies to track the referral. This is standard practice for affiliate programs and is governed by each retailer's own privacy policy.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Third-Party Services</h2>
      <ul class="list-disc pl-6 space-y-2" style="color: var(--color-text-secondary);">
        <li><strong style="color: var(--color-text-primary);">Google Analytics (GA4)</strong> — Usage analytics. <a href="https://policies.google.com/privacy" style="color: var(--color-text-primary); text-decoration: underline;" target="_blank" rel="noopener noreferrer">Google Privacy Policy</a></li>
        <li><strong style="color: var(--color-text-primary);">Amazon Associates</strong> — Affiliate program. <a href="https://www.amazon.co.jp/gp/help/customer/display.html?nodeId=GX7NJQ4ZB8MHFRNJ" style="color: var(--color-text-primary); text-decoration: underline;" target="_blank" rel="noopener noreferrer">Amazon Privacy Policy</a></li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Data Retention</h2>
      <p class="leading-relaxed" style="color: var(--color-text-secondary);">
        Analytics data is retained for 14 months in Google Analytics, after which it is automatically deleted. We do not store any personal data on our own servers.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Your Rights</h2>
      <p class="leading-relaxed mb-4" style="color: var(--color-text-secondary);">
        You can opt out of Google Analytics tracking by installing the <a href="https://tools.google.com/dlpage/gaoptout" style="color: var(--color-text-primary); text-decoration: underline;" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>. You can also disable cookies in your browser settings.
      </p>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-3" style="color: var(--color-text-primary);">Contact</h2>
      <p class="leading-relaxed" style="color: var(--color-text-secondary);">
        For privacy-related questions, contact us at <a href="mailto:hello@chartedly.com" style="color: var(--color-text-primary); text-decoration: underline;">hello@chartedly.com</a>.
      </p>
    </section>

  </div>
</BaseLayout>
