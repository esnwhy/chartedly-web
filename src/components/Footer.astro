---
const currentYear = new Date().getFullYear();

const linkGroups = [
  {
    title: 'Categories',
    links: [
      { label: 'Beauty', href: '/category/beauty' },
      { label: 'Tech', href: '/category/tech' },
      { label: 'Kitchen', href: '/category/kitchen' },
      { label: 'Health', href: '/category/health' },
      { label: 'Outdoor', href: '/category/outdoor' },
      { label: 'Living', href: '/category/living' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Methodology', href: '/about#methodology' },
      { label: 'Press', href: '/about' },
      { label: 'Contact', href: '/about' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Tokushoho', href: '/tokushoho' },
      { label: 'Cookie Policy', href: '/cookies' },
    ],
  },
  {
    title: 'Connect',
    links: [],
  },
];

const legalLinks = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'Tokushoho', href: '/tokushoho' },
  { label: 'Affiliate Disclosure', href: '/about#affiliate-disclosure' },
];
---

<footer class="border-t" style="background: var(--color-bg-deep); border-color: var(--color-border-subtle);" role="contentinfo">
  <div class="max-w-[1440px] mx-auto px-6 pt-16 pb-8">

    <!-- Top section: Logo/tagline + Newsletter -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-10 mb-12">

      <!-- Brand -->
      <div class="max-w-[280px]">
        <a href="/" class="inline-block mb-3">
          <span class="text-xl font-semibold tracking-tight" style="font-family: 'Inter', sans-serif; color: var(--color-text-primary);">
            Chartedly
          </span>
          <span class="text-[#4F7DF7] text-sm ml-1" aria-hidden="true">&#10022;</span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-tertiary);">
          Your guide to the best products for life in Japan.
        </p>
      </div>

      <!-- Newsletter -->
      <div class="w-full max-w-[400px]">
        <p class="text-sm font-semibold mb-3" style="color: var(--color-text-primary);">Newsletter</p>
        <div class="rounded-lg px-4 py-3" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);">
          <p class="text-sm" style="color: var(--color-text-secondary);">Newsletter launching soon. Stay tuned!</p>
          <p class="text-xs mt-1" style="color: var(--color-text-tertiary);">ニュースレターは近日公開予定です。</p>
        </div>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8 mb-12">
      {linkGroups.map((group) => (
        <nav aria-label={`${group.title} links`}>
          <h3 class="text-sm font-semibold mb-3" style="color: var(--color-text-primary);">{group.title}</h3>
          {group.links.length > 0 ? (
            <ul class="list-none p-0 m-0 flex flex-col gap-2">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm transition-colors duration-150 block py-0.5"
                    style="color: var(--color-text-tertiary);"
                    {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm" style="color: var(--color-text-tertiary);">Follow us — accounts launching soon</p>
          )}
        </nav>
      ))}
    </div>

    <!-- Divider -->
    <hr class="border-0 border-t mb-8" style="border-color: var(--color-border-subtle);" />

    <!-- Trust badges + Social -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 mb-8">
      <!-- Trust badges -->
      <div class="flex flex-wrap gap-3">
        <div class="footer-trust-badge flex items-center gap-1.5 h-9 px-3 rounded text-[10px] font-medium tracking-wide">
          <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          Independent
        </div>
        <div class="footer-trust-badge flex items-center gap-1.5 h-9 px-3 rounded text-[10px] font-medium tracking-wide">
          <svg class="w-4 h-4 text-[#4F7DF7]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
          AI-Powered
        </div>
        <div class="footer-trust-badge flex items-center gap-1.5 h-9 px-3 rounded text-[10px] font-medium tracking-wide">
          <svg class="w-4 h-4 text-[#F7A94F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          No Sponsored Rankings
        </div>
      </div>

      <!-- Social — coming soon -->
      <p class="text-xs" style="color: var(--color-text-tertiary);">Social accounts launching soon</p>
    </div>

    <!-- Bottom legal row -->
    <div class="flex flex-wrap items-center justify-between gap-4">
      <p class="text-xs" style="color: var(--color-text-disabled);">
        &copy; {currentYear} Chartedly. All rights reserved. A LAIRIA Holdings property.
      </p>
      <nav class="flex flex-wrap items-center gap-4" aria-label="Legal links">
        {legalLinks.map((link, i) => (
          <>
            <a
              href={link.href}
              class="text-xs transition-colors duration-150" style="color: var(--color-text-disabled);"
            >
              {link.label}
            </a>
            {i < legalLinks.length - 1 && (
              <span style="color: var(--color-text-disabled);" aria-hidden="true">&middot;</span>
            )}
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-trust-badge {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-tertiary);
  }
</style>
