---
import ScoreBadge from './ScoreBadge.astro';

interface Props {
  name: string;
  brand: string;
  image?: string;
  slug: string;
  category: string;
  subcategory: string;
  type: string;
  score: number;
  rank?: number;
  badge?: 'top-pick' | 'budget-pick';
  price: string;
  description?: string;
  rating?: number;
  reviewCount?: number;
  skeleton?: boolean;
}

const {
  name,
  brand,
  image,
  slug,
  category,
  subcategory,
  type,
  score,
  rank,
  badge,
  price,
  description,
  rating,
  reviewCount,
  skeleton = false,
} = Astro.props;

// Rank badge colors (1-3 gold, 4-10 gray)
const rankColors: Record<number, { bg: string; text: string }> = {
  1: { bg: '#FFD700', text: '#1a1a1a' },
  2: { bg: '#C0C0C0', text: '#1a1a1a' },
  3: { bg: '#CD7F32', text: '#1a1a1a' },
};
const rankStyle = rank && rank <= 10
  ? rank <= 3
    ? rankColors[rank]
    : { bg: '#374151', text: '#ffffff' }
  : null;

// Award badge
const badgeConfig = badge === 'top-pick'
  ? { label: 'Top Pick', bg: 'bg-[#F59E0B]/15', text: 'text-[#F59E0B]', border: 'border-[#F59E0B]/30' }
  : badge === 'budget-pick'
    ? { label: 'Budget Pick', bg: 'bg-[#22C55E]/15', text: 'text-[#22C55E]', border: 'border-[#22C55E]/30' }
    : null;

// Star rating display
function renderStars(r: number): string {
  const full = Math.floor(r);
  const half = r - full >= 0.5 ? 1 : 0;
  const empty = 5 - full - half;
  return '\u2605'.repeat(full) + (half ? '\u00BD' : '') + '\u2606'.repeat(empty);
}

// Accessible label
const ariaLabel = `${name}, Score ${score}, ${price}`;
---

{skeleton ? (
  <!-- Skeleton loading state -->
  <div
    class="product-card product-card--skeleton block rounded-xl overflow-hidden border"
    style="border-color: var(--color-border-subtle); background: var(--color-surface-card);"
    aria-busy="true"
    aria-label="Loading product"
  >
    <div class="skeleton-shimmer aspect-[16/10]" style="background: var(--color-bg-base);" />
    <div class="p-4 flex flex-col gap-3">
      <div class="skeleton-shimmer h-3 w-[45%] rounded" />
      <div class="skeleton-shimmer h-4 w-[85%] rounded" />
      <div class="skeleton-shimmer h-4 w-[60%] rounded" />
      <div class="skeleton-shimmer h-3.5 w-[40%] rounded" />
      <div class="flex justify-between mt-1">
        <div class="skeleton-shimmer h-4 w-[30%] rounded" />
        <div class="skeleton-shimmer h-3.5 w-[25%] rounded" />
      </div>
    </div>
  </div>
) : (
  <!-- Real product card -->
  <a
    href={`/product/${slug}`}
    class="product-card group block rounded-xl overflow-hidden relative border cursor-pointer"
    style="border-color: var(--color-border-subtle); background: var(--color-surface-card);"
    aria-label={ariaLabel}
  >
    <!-- Image area — fixed square aspect ratio for uniform card heights -->
    <div class="relative aspect-square overflow-hidden" style="background: var(--color-surface-elevated);">
      {image ? (
        <img
          src={image}
          alt={`${name} by ${brand}`}
          class="w-full h-full object-contain p-3 transition-transform duration-300 ease-out group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center p-6" style="background: linear-gradient(to bottom right, var(--color-surface-elevated), var(--color-surface-card));">
          <span class="text-xl font-bold text-center leading-tight" style="color: var(--color-text-tertiary);">{brand}</span>
        </div>
      )}

      <!-- Dark gradient overlay to blend product images into dark card -->
      <div class="absolute inset-0 pointer-events-none card-image-gradient" />

      <!-- Rank badge — top-left overlay -->
      {rankStyle && rank && rank <= 10 && (
        <div
          class="absolute top-3 left-3 w-8 h-8 rounded-full flex items-center justify-center text-sm font-extrabold shadow-md"
          style={`background: ${rankStyle.bg}; color: ${rankStyle.text};`}
          aria-label={`Ranked number ${rank}`}
        >
          {rank}
        </div>
      )}

      <!-- Award badge — top-right overlay -->
      {badgeConfig && (
        <span
          class:list={[
            'absolute top-3 right-3 z-10 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border shadow-lg backdrop-blur-sm',
            badgeConfig.bg,
            badgeConfig.text,
            badgeConfig.border,
          ]}
        >
          {badge === 'top-pick' ? '\u2605' : '\u2713'} {badgeConfig.label}
        </span>
      )}

      <!-- Score badge — bottom-right inside image -->
      <div class="absolute bottom-3 right-3 z-10">
        <ScoreBadge score={score} size="sm" />
      </div>
    </div>

    <!-- Card body — fixed height, content pushed to edges -->
    <div class="p-4 flex flex-col h-[115px]">
      <!-- Category overline -->
      <span class="text-xs font-semibold tracking-[0.08em] uppercase" style="color: var(--color-text-tertiary);">
        {category} &middot; {subcategory}
      </span>

      <!-- Product title — 2-line clamp -->
      <h3 class="text-base font-semibold leading-[1.2] line-clamp-2 mt-1.5" style="color: var(--color-text-primary);">
        {name}
      </h3>

      <!-- Spacer pushes price to bottom -->
      <div class="flex-grow" />

      <!-- Price -->
      <span class="text-base font-semibold tabular-nums" style="font-family: 'Inter', sans-serif; color: var(--color-text-primary);">
        {price}
      </span>
    </div>
  </a>
)}

<style>
  /* Card image gradient overlay */
  .card-image-gradient {
    background: linear-gradient(to bottom, transparent 40%, rgba(22, 22, 42, 0.6) 80%, var(--color-surface-card) 100%);
  }

  /* Base card transitions */
  .product-card:not(.product-card--skeleton) {
    box-shadow: var(--shadow-card);
    transition: transform 300ms ease-out, box-shadow 300ms ease-out, border-color 300ms ease-out;
  }

  /* Hover */
  .product-card:not(.product-card--skeleton):hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 8px 24px rgba(79, 125, 247, 0.15);
    border-color: rgba(79, 125, 247, 0.3);
  }

  /* Active / pressed */
  .product-card:not(.product-card--skeleton):active {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    background: var(--color-surface-pressed);
  }

  /* Focus visible */
  .product-card:not(.product-card--skeleton):focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(79, 125, 247, 0.5);
    border-color: #4F7DF7;
  }

  /* Touch: disable hover transform */
  @media (hover: none) {
    .product-card:not(.product-card--skeleton):hover {
      transform: none !important;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25) !important;
      border-color: var(--color-border-subtle) !important;
    }
  }

  /* Carousel context */
  .carousel .product-card {
    min-width: 280px;
    max-width: 280px;
    flex-shrink: 0;
  }

  /* Grid context */
  .product-grid .product-card {
    width: 100%;
  }

  /* Mobile */
  @media (max-width: 639px) {
    .product-card {
      min-width: 100%;
      max-width: 100%;
    }
  }

  /* Skeleton shimmer */
  .skeleton-shimmer {
    background: linear-gradient(
      90deg,
      var(--color-surface-card) 0%,
      var(--color-surface-elevated) 50%,
      var(--color-surface-card) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton-shimmer {
      animation: none;
      background: var(--color-surface-elevated);
    }
  }
</style>
