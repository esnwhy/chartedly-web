---
import { ChevronLeft, ChevronRight, ArrowRight } from 'lucide-astro';

interface FeaturedProduct {
  name: string;
  brand: string;
  category: string;
  subcategory: string;
  type: string;
  slug: string;
  image?: string;
  shortDescription: string;
  score: number;
  badge?: 'top-pick' | 'budget-pick';
}

interface Props {
  products: FeaturedProduct[];
}

const { products } = Astro.props;
const maxSlides = products.slice(0, 5);

const scoreColor = (s: number) =>
  s >= 80 ? '#22C55E' : s >= 60 ? '#F59E0B' : '#EF4444';
---

<section
  class="hero relative w-full overflow-hidden"
  role="region"
  aria-roledescription="carousel"
  aria-label="Featured products"
>
  <!-- Slides container — crossfade approach -->
  <div class="hero__slides relative w-full h-full">
    {maxSlides.map((product, i) => (
      <div
        class:list={[
          'hero__slide absolute inset-0 transition-opacity duration-400',
          i === 0 ? 'hero__slide--active' : '',
        ]}
        role="group"
        aria-roledescription="slide"
        aria-label={`${i + 1} of ${maxSlides.length}`}
        data-slide-index={i}
      >
        <!-- Background image -->
        {product.image ? (
          <img
            src={product.image}
            alt={product.name}
            class="hero__image absolute inset-0 w-full h-full object-cover object-[center_30%]"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e] via-[#2a2a3e] to-[#1a1a2e]" />
        )}

        <!-- Gradient overlay -->
        <div class="hero__overlay absolute inset-0 z-[1]" />

        <!-- Text content -->
        <div class="hero__content z-[2]">
          <!-- Category breadcrumb -->
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs font-semibold tracking-[0.08em] uppercase text-[#4F7DF7]">
              {product.category}
            </span>
            <span class="text-white/30 text-xs">/</span>
            <span class="text-xs font-semibold tracking-[0.08em] uppercase text-[#4F7DF7]">
              {product.subcategory}
            </span>
            <span class="text-white/30 text-xs">/</span>
            <span class="text-xs font-semibold tracking-[0.08em] uppercase text-white/80">
              {product.type}
            </span>
          </div>

          <!-- Badge -->
          {product.badge === 'top-pick' && (
            <span class="inline-block text-xs font-semibold bg-[#4F7DF7] text-white px-3 py-1 rounded-full w-fit">
              &#9733; #1 Top Pick
            </span>
          )}
          {product.badge === 'budget-pick' && (
            <span class="inline-block text-xs font-semibold bg-[#22C55E] text-white px-3 py-1 rounded-full w-fit">
              &#10003; Budget Pick
            </span>
          )}

          <!-- Title -->
          <h2 class="hero__title">{product.name}</h2>

          <!-- Description -->
          <p class="hero__subtitle line-clamp-2">{product.shortDescription}</p>

          <!-- Score + CTA row -->
          <div class="flex items-center gap-4 flex-wrap">
            <a
              href={`/product/${product.slug}`}
              class="hero__cta"
            >
              View Details
              <ArrowRight size={16} />
            </a>
            <div class="flex items-center gap-2">
              <span
                class="inline-flex items-center justify-center h-7 px-2 rounded-full text-sm font-bold text-white gap-0.5"
                style={`background: ${scoreColor(product.score)};`}
              >
                {(product.score / 10).toFixed(1)}<span class="text-[9px] opacity-80">/10</span>
              </span>
              <span class="text-sm text-white/50">
                {product.brand}
              </span>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Arrow navigation — appear on hover -->
  {maxSlides.length > 1 && (
    <>
      <button
        class="hero-arrow hero-prev absolute left-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full backdrop-blur-sm flex items-center justify-center transition-all duration-200 cursor-pointer"
        style="background: var(--color-surface-overlay); border: 1px solid var(--color-border-subtle); color: var(--color-text-secondary);"
        aria-label="Previous slide"
      >
        <ChevronLeft size={22} />
      </button>
      <button
        class="hero-arrow hero-next absolute right-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full backdrop-blur-sm flex items-center justify-center transition-all duration-200 cursor-pointer"
        style="background: var(--color-surface-overlay); border: 1px solid var(--color-border-subtle); color: var(--color-text-secondary);"
        aria-label="Next slide"
      >
        <ChevronRight size={22} />
      </button>
    </>
  )}

  <!-- Progress dots -->
  {maxSlides.length > 1 && (
    <div class="hero__dots absolute bottom-6 left-1/2 -translate-x-1/2 z-[3] flex items-center gap-2">
      {maxSlides.map((_, i) => (
        <button
          class:list={[
            'hero__dot',
            i === 0 ? 'hero__dot--active' : '',
          ]}
          data-dot-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</section>

<style>
  /* Container */
  .hero {
    height: 560px;
  }
  @media (max-width: 1023px) {
    .hero { height: 440px; }
  }
  @media (max-width: 639px) {
    .hero { height: 400px; }
  }

  /* Parallax (desktop, respects motion preference) */
  @media (min-width: 1024px) and (prefers-reduced-motion: no-preference) {
    .hero__image {
      transform: translateY(var(--scroll-y, 0));
      will-change: transform;
    }
  }

  /* Slides — crossfade */
  .hero__slide {
    opacity: 0;
    pointer-events: none;
  }
  .hero__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Gradient overlay — bottom + left protection */
  .hero__overlay {
    background:
      linear-gradient(
        to top,
        var(--color-bg-base) 0%,
        rgba(23, 23, 23, 0.85) 15%,
        rgba(23, 23, 23, 0.4) 50%,
        rgba(23, 23, 23, 0.2) 100%
      ),
      linear-gradient(
        to right,
        rgba(23, 23, 23, 0.7) 0%,
        rgba(23, 23, 23, 0.3) 40%,
        transparent 70%
      );
  }

  /* Content positioning */
  .hero__content {
    position: absolute;
    bottom: 80px;
    left: 0;
    right: 0;
    max-width: 600px;
    margin-left: max(24px, calc((100vw - 1440px) / 2 + 24px));
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  @media (max-width: 639px) {
    .hero__content {
      bottom: 64px;
      padding: 0 16px;
      margin-left: 16px;
      max-width: calc(100vw - 32px);
      gap: 12px;
    }
  }

  /* Typography */
  .hero__title {
    font-family: 'Inter', sans-serif;
    font-size: 3.75rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }
  @media (max-width: 639px) {
    .hero__title { font-size: 2.25rem; }
  }

  .hero__subtitle {
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 480px;
  }
  @media (max-width: 639px) {
    .hero__subtitle { font-size: 1rem; }
  }

  /* CTA button */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: #4F7DF7;
    color: #FFFFFF;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: background 150ms ease, transform 150ms ease;
    width: fit-content;
    text-decoration: none;
  }
  .hero__cta:hover {
    background: #6890F9;
    transform: translateY(-1px);
  }
  .hero__cta:hover :global(svg) {
    transform: translateX(3px);
  }
  .hero__cta:active {
    transform: translateY(0);
    background: #3D65D4;
  }
  .hero__cta :global(svg) {
    width: 16px;
    height: 16px;
    transition: transform 150ms ease;
  }

  /* Arrow navigation — hidden until hero hover */
  .hero-arrow {
    opacity: 0;
    transition: opacity 200ms ease, background-color 200ms ease, transform 200ms ease;
  }
  .hero:hover .hero-arrow {
    opacity: 1;
  }
  .hero-arrow:hover {
    transform: translateY(-50%) scale(1.05);
  }
  .hero-arrow:active {
    transform: translateY(-50%) scale(0.95);
  }
  @media (hover: none) {
    .hero-arrow {
      opacity: 1;
    }
  }
  @media (max-width: 639px) {
    .hero-arrow {
      display: none;
    }
  }

  /* Progress dots */
  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 150ms ease, width 300ms ease;
  }
  .hero__dot:hover {
    background: rgba(255, 255, 255, 0.6);
  }
  .hero__dot--active {
    width: 24px;
    background: linear-gradient(
      to right,
      #FFFFFF var(--progress, 0%),
      rgba(255, 255, 255, 0.3) var(--progress, 0%)
    );
  }
</style>

<script>
  function initHeroCarousel() {
    const hero = document.querySelector<HTMLElement>('.hero');
    const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
    const dots = document.querySelectorAll<HTMLElement>('.hero__dot');
    const prevBtn = document.querySelector<HTMLElement>('.hero-prev');
    const nextBtn = document.querySelector<HTMLElement>('.hero-next');

    if (!hero || slides.length <= 1) return;

    const slideCount = slides.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    let progressTimer: ReturnType<typeof setInterval>;
    let isPaused = false;
    const SLIDE_DURATION = 8000;
    const PROGRESS_INTERVAL = 50;

    function goTo(index: number) {
      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;

      slides[current]?.classList.remove('hero__slide--active');
      dots[current]?.classList.remove('hero__dot--active');
      if (dots[current]) {
        (dots[current] as HTMLElement).style.setProperty('--progress', '0%');
      }

      current = index;

      slides[current]?.classList.add('hero__slide--active');
      dots[current]?.classList.add('hero__dot--active');
    }

    function startProgress() {
      let elapsed = 0;
      clearInterval(progressTimer);
      if (dots[current]) {
        (dots[current] as HTMLElement).style.setProperty('--progress', '0%');
      }
      progressTimer = setInterval(() => {
        if (isPaused) return;
        elapsed += PROGRESS_INTERVAL;
        const pct = Math.min(100, (elapsed / SLIDE_DURATION) * 100);
        if (dots[current]) {
          (dots[current] as HTMLElement).style.setProperty('--progress', `${pct}%`);
        }
      }, PROGRESS_INTERVAL);
    }

    function resetTimer() {
      clearInterval(timer);
      startProgress();
      timer = setInterval(() => {
        if (!isPaused) {
          goTo(current + 1);
          startProgress();
        }
      }, SLIDE_DURATION);
    }

    // Pause on hover / focus
    hero.addEventListener('mouseenter', () => { isPaused = true; });
    hero.addEventListener('mouseleave', () => { isPaused = false; });
    hero.addEventListener('focusin', () => { isPaused = true; });
    hero.addEventListener('focusout', () => { isPaused = false; });

    // Arrow buttons
    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetTimer(); });

    // Dot buttons
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); resetTimer(); });
    });

    // Touch/swipe support
    let touchStartX = 0;
    hero.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    hero.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        goTo(diff > 0 ? current + 1 : current - 1);
        resetTimer();
      }
    }, { passive: true });

    // Parallax on scroll (desktop only)
    if (window.matchMedia('(min-width: 1024px) and (prefers-reduced-motion: no-preference)').matches) {
      const activeImage = () => slides[current]?.querySelector<HTMLElement>('.hero__image');
      window.addEventListener('scroll', () => {
        const img = activeImage();
        if (img) {
          img.style.setProperty('--scroll-y', `${window.scrollY * 0.15}px`);
        }
      }, { passive: true });
    }

    // Start
    resetTimer();
  }

  initHeroCarousel();
  document.addEventListener('astro:page-load', initHeroCarousel);
</script>
