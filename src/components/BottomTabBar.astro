---
import { Home, Search, Trophy, Sparkles } from 'lucide-astro';

const pathname = Astro.url.pathname;

const tabs = [
  { label: 'Home', href: '/', icon: Home },
  { label: 'Search', href: '/explore', icon: Search },
  { label: 'Rankings', href: '/ranking', icon: Trophy },
  { label: 'New', href: '/new', icon: Sparkles },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav
  class="tab-bar fixed bottom-0 inset-x-0 z-50 border-t border-[#2D2D4A] sm:hidden"
  role="navigation"
  aria-label="Quick navigation"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <ul class="flex items-stretch h-14 list-none m-0 p-0">
    {tabs.map(({ label, href, icon: Icon }) => {
      const active = isActive(href);
      return (
        <li class="flex-1">
          <a
            href={href}
            class:list={[
              'flex flex-col items-center justify-center gap-0.5 h-full transition-colors duration-150',
              active ? 'text-[#4F7DF7]' : 'text-[#6B7280]',
            ]}
            aria-current={active ? 'page' : undefined}
            style="-webkit-tap-highlight-color: transparent;"
          >
            <Icon size={22} />
            <span class="text-[10px] font-medium tracking-wide">{label}</span>
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .tab-bar {
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
  }

  /* Add bottom padding to body to prevent content overlap */
  @media (max-width: 639px) {
    :global(body) {
      padding-bottom: calc(56px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
