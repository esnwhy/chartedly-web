---
interface Props {
  score: number;
  size?: 'sm' | 'lg';
}

const { score, size = 'sm' } = Astro.props;

// Convert 0-100 to 0-10 scale for display
const displayScore = (score / 10).toFixed(1);

// Color thresholds
const scoreColor = score >= 80 ? '#22C55E' : score >= 60 ? '#F59E0B' : '#EF4444';
const scoreLabel = score >= 80 ? 'Excellent' : score >= 60 ? 'Good' : 'Needs Work';

// Large badge SVG math
const circumference = 2 * Math.PI * 52; // 326.73
const offset = circumference * (1 - score / 100);
---

{size === 'sm' ? (
  <!-- Small badge: pill shape on product card -->
  <div
    class="h-7 px-2 rounded-full flex items-center justify-center gap-0.5 font-bold text-white border-2 border-[#16162A] tabular-nums whitespace-nowrap"
    style={`background: ${scoreColor}; font-family: 'Inter', sans-serif;`}
    aria-label={`Score ${displayScore} out of 10`}
  >
    <span class="text-sm leading-none">{displayScore}</span>
    <span class="text-[9px] leading-none opacity-80">/10</span>
  </div>
) : (
  <!-- Large badge: 120px ring for product detail -->
  <div
    class="score-badge-lg relative w-[120px] h-[120px]"
    role="img"
    aria-label={`Score ${score} out of 100, ${scoreLabel}`}
  >
    <svg viewBox="0 0 120 120" width="120" height="120" class="block">
      <!-- Background ring -->
      <circle
        cx="60" cy="60" r="52"
        fill="none"
        stroke="#2D2D4A"
        stroke-width="8"
      />
      <!-- Score ring (animated fill) -->
      <circle
        class="score-ring"
        cx="60" cy="60" r="52"
        fill="none"
        stroke={scoreColor}
        stroke-width="8"
        stroke-linecap="round"
        stroke-dasharray={circumference}
        stroke-dashoffset={circumference}
        transform="rotate(-90 60 60)"
        style={`--score-offset: ${offset};`}
      />
    </svg>
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-0.5">
      <span
        class="text-3xl font-bold leading-none tracking-tight tabular-nums"
        style={`color: ${scoreColor}; font-family: 'Inter', sans-serif; letter-spacing: -0.02em;`}
      >
        {displayScore}
      </span>
      <span
        class="text-[10px] font-medium tracking-wide"
        style="color: #6B7280;"
      >
        / 10
      </span>
    </div>
  </div>
)}

<style>
  /* Animated fill for large badge */
  .score-ring {
    animation: score-fill 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    animation-delay: 200ms;
  }

  @keyframes score-fill {
    to {
      stroke-dashoffset: var(--score-offset);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .score-ring {
      animation: none;
      stroke-dashoffset: var(--score-offset);
    }
  }
</style>
