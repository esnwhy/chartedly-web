---
import { Search, Globe, Menu, X } from 'lucide-astro';

const pathname = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/', i18nKey: 'nav.home' },
  { label: 'Explore', href: '/explore', i18nKey: 'nav.explore' },
  { label: 'Rankings', href: '/ranking', i18nKey: 'nav.ranking' },
  { label: "What's New", href: '/new', i18nKey: 'nav.whatsNew' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!-- Skip to content link -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[200] focus:bg-[#4F7DF7] focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-medium"
>
  Skip to content
</a>

<nav
  class="nav fixed top-0 inset-x-0 z-50 h-16 border-b"
  style="border-color: var(--color-border-subtle);"
  role="navigation"
  aria-label="Main navigation"
>
  <div class="max-w-[1440px] mx-auto h-full px-6 flex items-center justify-between">

    <!-- Left: Logo -->
    <a href="/" class="shrink-0 flex items-center gap-1.5 group">
      <span class="text-xl font-semibold tracking-tight" style="font-family: 'Inter', sans-serif; color: var(--color-text-primary);">
        Chartedly
      </span>
      <span class="text-[#4F7DF7] text-sm" aria-hidden="true">&#10022;</span>
    </a>

    <!-- Center: Nav links (desktop) -->
    <ul class="nav__links hidden md:flex items-center gap-8 list-none m-0 p-0 absolute left-1/2 -translate-x-1/2">
      {navItems.map(({ label, href, i18nKey }) => {
        const active = isActive(href);
        return (
          <li>
            <a
              href={href}
              class:list={[
                'nav__link relative text-sm font-medium py-1 transition-colors duration-150',
                active ? 'nav__link--active text-white' : 'text-[#9CA3AF] hover:text-white',
              ]}
              aria-current={active ? 'page' : undefined}
              data-i18n={i18nKey}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right: Search + Language + Mobile hamburger -->
    <div class="flex items-center gap-4">
      <!-- Search button -->
      <button
        id="nav-search-trigger"
        class="nav__search-btn nav__icon-btn w-9 h-9 rounded-full bg-transparent flex items-center justify-center transition-all duration-150 cursor-pointer"
        style="border: 1px solid var(--color-border-subtle); color: var(--color-text-secondary);"
        aria-label="Search (Ctrl+K)"
      >
        <Search size={18} />
      </button>

      <!-- Theme toggle (dark/light) -->
      <button
        id="theme-toggle"
        class="nav__icon-btn w-9 h-9 rounded-full bg-transparent flex items-center justify-center transition-all duration-150 cursor-pointer"
        style="border: 1px solid var(--color-border-subtle); color: var(--color-text-secondary);"
        aria-label="Toggle dark/light mode"
      >
        <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>

      <!-- Language toggle -->
      <div
        class="nav__lang-toggle hidden sm:flex items-center rounded-full p-0.5 h-8"
        style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);"
        role="radiogroup"
        aria-label="Language"
      >
        <button
          class="nav__lang-option nav__lang-option--active px-3 py-1 text-xs font-semibold tracking-wide rounded-full border-none cursor-pointer transition-all duration-150"
          role="radio"
          aria-checked="true"
          data-lang="en"
        >
          EN
        </button>
        <button
          class="nav__lang-option px-3 py-1 text-xs font-semibold tracking-wide rounded-full border-none cursor-pointer transition-all duration-150"
          role="radio"
          aria-checked="false"
          data-lang="ja"
        >
          JP
        </button>
      </div>

      <!-- Mobile: Globe shortcut for language (visible on small screens only) -->
      <button
        class="sm:hidden w-9 h-9 rounded-full bg-transparent flex items-center justify-center transition-colors duration-150 cursor-pointer"
        style="color: var(--color-text-secondary);"
        aria-label="Switch language"
        id="mobile-lang-btn"
      >
        <Globe size={18} />
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-9 h-9 rounded-full bg-transparent flex items-center justify-center transition-colors duration-150 cursor-pointer"
        style="color: var(--color-text-secondary);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <Menu size={20} id="menu-icon-open" />
        <X size={20} id="menu-icon-close" class="hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu-panel"
    class="md:hidden hidden border-t backdrop-blur-xl"
    style="border-color: var(--color-border-subtle); background: var(--color-surface-overlay);"
  >
    <div class="px-4 py-3 flex flex-col gap-1">
      {navItems.map(({ label, href, i18nKey }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            class:list={[
              'px-4 py-2.5 text-sm font-medium rounded-lg transition-colors duration-150',
              active
                ? 'text-[#4F7DF7] bg-[#4F7DF7]/10'
                : 'text-[#9CA3AF] hover:text-white hover:bg-white/[0.06]',
            ]}
            aria-current={active ? 'page' : undefined}
            data-i18n={i18nKey}
          >
            {label}
          </a>
        );
      })}
    </div>
  </div>
</nav>

<style>
  /* Sticky nav background */
  .nav {
    background: var(--color-surface-overlay);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    transition: background 200ms ease;
  }

  /* Scrolled: more opaque */
  .nav--scrolled {
    background: var(--color-surface-overlay);
  }

  /* Icon buttons hover */
  .nav__icon-btn:hover {
    background: var(--color-surface-card);
    color: var(--color-text-primary);
    border-color: var(--color-border-default);
  }

  /* Active link underline — aligned with nav bottom border */
  .nav__link--active::after {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 0;
    right: 0;
    height: 2px;
    background: #4F7DF7;
    border-radius: 1px;
  }

  /* Language toggle */
  .nav__lang-option {
    background: transparent;
    color: var(--color-text-tertiary);
  }
  .nav__lang-option--active {
    background: #4F7DF7;
    color: #FFFFFF;
  }
  .nav__lang-option:hover:not(.nav__lang-option--active) {
    color: var(--color-text-secondary);
  }

  /* Mobile: simplified nav */
  @media (max-width: 767px) {
    .nav {
      height: 56px;
    }
  }
</style>

<script>
  // ── Theme Toggle ──
  function initTheme() {
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('theme-icon-sun');
    const moonIcon = document.getElementById('theme-icon-moon');
    if (!toggle || !sunIcon || !moonIcon) return;

    function getPreferred(): string {
      const saved = localStorage.getItem('theme');
      if (saved) return saved;
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    function applyTheme(theme: string) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      if (theme === 'light') {
        sunIcon.classList.remove('hidden');
        moonIcon.classList.add('hidden');
      } else {
        sunIcon.classList.add('hidden');
        moonIcon.classList.remove('hidden');
      }
    }

    // Apply on load
    applyTheme(getPreferred());

    // Toggle on click
    toggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });

    // Listen for system changes
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        applyTheme(e.matches ? 'light' : 'dark');
      }
    });
  }
  initTheme();

  function initTopNav() {
    const nav = document.querySelector<HTMLElement>('.nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuPanel = document.getElementById('mobile-menu-panel');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    const searchTrigger = document.getElementById('nav-search-trigger');

    // Scroll: toggle opaque state
    if (nav) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 10) {
          nav.classList.add('nav--scrolled');
        } else {
          nav.classList.remove('nav--scrolled');
        }
      }, { passive: true });
    }

    // Mobile menu toggle
    menuBtn?.addEventListener('click', () => {
      const isOpen = menuPanel && !menuPanel.classList.contains('hidden');
      menuPanel?.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Search trigger — opens SearchOverlay
    searchTrigger?.addEventListener('click', () => {
      const overlay = document.getElementById('search-overlay');
      if (overlay) {
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        const input = overlay.querySelector<HTMLInputElement>('input');
        setTimeout(() => input?.focus(), 100);
      }
    });

    // Cmd/Ctrl+K to open search
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const overlay = document.getElementById('search-overlay');
        if (overlay) {
          const isHidden = overlay.classList.contains('hidden');
          if (isHidden) {
            overlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            const input = overlay.querySelector<HTMLInputElement>('input');
            setTimeout(() => input?.focus(), 100);
          } else {
            overlay.classList.add('hidden');
            document.body.style.overflow = '';
          }
        }
      }
    });

    // Language toggle
    const langOptions = document.querySelectorAll<HTMLElement>('.nav__lang-option');
    langOptions.forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.getAttribute('data-lang') as 'en' | 'ja';
        if (!lang) return;

        // Update toggle UI
        langOptions.forEach((b) => {
          b.classList.remove('nav__lang-option--active');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.add('nav__lang-option--active');
        btn.setAttribute('aria-checked', 'true');

        // Apply language via i18n client
        localStorage.setItem('chartedly-lang', lang);
        document.documentElement.lang = lang;
        // Dispatch for any listeners
        window.dispatchEvent(new CustomEvent('chartedly-lang-change', { detail: { lang } }));
        // Use the i18n client if available
        if (typeof (window as any).__chartelySetLang === 'function') {
          (window as any).__chartelySetLang(lang);
        }
      });
    });

    // Mobile language toggle (cycles en/ja)
    const mobileLangBtn = document.getElementById('mobile-lang-btn');
    mobileLangBtn?.addEventListener('click', () => {
      const current = localStorage.getItem('chartedly-lang') || 'en';
      const next = current === 'en' ? 'ja' : 'en';
      // Update desktop toggle UI if visible
      langOptions.forEach((b) => {
        const bLang = b.getAttribute('data-lang');
        if (bLang === next) {
          b.classList.add('nav__lang-option--active');
          b.setAttribute('aria-checked', 'true');
        } else {
          b.classList.remove('nav__lang-option--active');
          b.setAttribute('aria-checked', 'false');
        }
      });
      localStorage.setItem('chartedly-lang', next);
      document.documentElement.lang = next;
      window.dispatchEvent(new CustomEvent('chartedly-lang-change', { detail: { lang: next } }));
      if (typeof (window as any).__chartelySetLang === 'function') {
        (window as any).__chartelySetLang(next);
      }
    });

    // Sync toggle UI with stored language on load
    const storedLang = localStorage.getItem('chartedly-lang') || (navigator.language.toLowerCase().startsWith('ja') ? 'ja' : 'en');
    langOptions.forEach((b) => {
      const bLang = b.getAttribute('data-lang');
      if (bLang === storedLang) {
        b.classList.add('nav__lang-option--active');
        b.setAttribute('aria-checked', 'true');
      } else {
        b.classList.remove('nav__lang-option--active');
        b.setAttribute('aria-checked', 'false');
      }
    });
  }

  initTopNav();
  document.addEventListener('astro:page-load', initTopNav);
</script>
