---
interface Props {
  radar: {
    quality: number;
    value: number;
    popularity: number;
    ease: number;
    innovation: number;
  };
}

const { radar } = Astro.props;

const dimensions = [
  { label: 'Quality', value: radar.quality },
  { label: 'Value', value: radar.value },
  { label: 'Popularity', value: radar.popularity },
  { label: 'Ease', value: radar.ease },
  { label: 'Innovation', value: radar.innovation },
];

const size = 280;
const cx = size / 2; // 140
const cy = size / 2; // 140
const maxRadius = 110;
const numAxes = 5;
const angleStep = (2 * Math.PI) / numAxes;
const startAngle = -Math.PI / 2; // Start from top

// Generate polygon points for a given uniform or per-axis values
function getPolygonPoints(values: number[]): string {
  return values.map((val, i) => {
    const angle = startAngle + i * angleStep;
    const r = (val / 100) * maxRadius;
    const x = cx + r * Math.cos(angle);
    const y = cy + r * Math.sin(angle);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
}

// Grid levels at 20%, 40%, 60%, 80%, 100%
const gridLevels = [20, 40, 60, 80, 100];

// Axis line endpoints
const axisEndpoints = dimensions.map((_, i) => {
  const angle = startAngle + i * angleStep;
  return {
    x: cx + maxRadius * Math.cos(angle),
    y: cy + maxRadius * Math.sin(angle),
  };
});

// Label positions — outside the chart
const labelPositions = dimensions.map((dim, i) => {
  const angle = startAngle + i * angleStep;
  const labelR = maxRadius + 24;
  return {
    x: cx + labelR * Math.cos(angle),
    y: cy + labelR * Math.sin(angle),
    label: dim.label,
    value: dim.value,
  };
});

// Data polygon
const dataPoints = getPolygonPoints(dimensions.map(d => d.value));

// Data dots
const dataDots = dimensions.map((dim, i) => {
  const angle = startAngle + i * angleStep;
  const r = (dim.value / 100) * maxRadius;
  return {
    x: cx + r * Math.cos(angle),
    y: cy + r * Math.sin(angle),
  };
});

// Accessible label
const ariaLabel = dimensions.map(d => `${d.label} ${d.value}`).join(', ');
---

<div
  class="radar-chart inline-block w-[280px] h-[280px] md:w-[280px] md:h-[280px]"
  role="img"
  aria-label={ariaLabel}
>
  <svg
    viewBox={`0 0 ${size} ${size}`}
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
  >
    <!-- Grid polygons (concentric pentagons) -->
    {gridLevels.map((level) => (
      <polygon
        points={getPolygonPoints(Array(numAxes).fill(level))}
        fill="none"
        stroke="#2D2D4A"
        stroke-width="1"
      />
    ))}

    <!-- Axis lines from center to vertices (dashed) -->
    {axisEndpoints.map((point) => (
      <line
        x1={cx} y1={cy}
        x2={point.x} y2={point.y}
        stroke="#2D2D4A"
        stroke-width="1"
        stroke-dasharray="4 4"
      />
    ))}

    <!-- Data polygon — filled area -->
    <polygon
      class="radar-chart__data"
      points={dataPoints}
      fill="rgba(79, 125, 247, 0.15)"
      stroke="#4F7DF7"
      stroke-width="2"
      stroke-linejoin="round"
    />

    <!-- Data dots at each vertex -->
    {dataDots.map((dot) => (
      <circle
        cx={dot.x.toFixed(1)}
        cy={dot.y.toFixed(1)}
        r="3"
        fill="#4F7DF7"
      />
    ))}

    <!-- Axis labels -->
    {labelPositions.map((lp) => (
      <text
        x={lp.x.toFixed(1)}
        y={lp.y.toFixed(1)}
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#9CA3AF"
        font-size="12"
        font-weight="500"
        style="font-family: 'Inter', sans-serif;"
      >
        {lp.label}
      </text>
    ))}
  </svg>
</div>

<style>
  /* Animate data polygon fade-in */
  .radar-chart__data {
    opacity: 0;
    animation: radar-fade 400ms ease-out 400ms forwards;
  }

  @keyframes radar-fade {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .radar-chart__data {
      animation: none;
      opacity: 1;
    }
  }

  /* Mobile: slightly smaller */
  @media (max-width: 639px) {
    .radar-chart {
      width: 200px !important;
      height: 200px !important;
    }
  }
</style>
